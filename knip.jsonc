{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/main.tsx",
    "src/ssg.tsx",
    "vite.config.ts",
    "playwright.config.ts",
    "jest.config.js",
    "scripts/**/*.mjs",
    "e2e/**/*.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{js,mjs,ts}",
    "e2e/**/*.ts",
    "*.config.{js,ts}"
  ],
  "ignore": [
    "archive/**",
    "public/sw.js",
    "public/spa-redirect.js",
    "src/**/*.d.ts"
  ]
}
