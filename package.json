{
  "name": "pack-website",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://trypackai.com",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/ssg.tsx --outDir dist-ssr && node scripts/prerender.mjs",
    "build:app-origin": "VITE_APP_BASE_URL=https://www.trypackai.com VITE_COGNITO_REDIRECT_URI=https://www.trypackai.com/auth/callback VITE_POST_LOGOUT_REDIRECT_URI=https://www.trypackai.com VITE_OAUTH_RESOURCE_SERVER_IDENTIFIER=api.trypackai.com vite build && VITE_APP_BASE_URL=https://www.trypackai.com VITE_COGNITO_REDIRECT_URI=https://www.trypackai.com/auth/callback VITE_POST_LOGOUT_REDIRECT_URI=https://www.trypackai.com VITE_OAUTH_RESOURCE_SERVER_IDENTIFIER=api.trypackai.com vite build --ssr src/ssg.tsx --outDir dist-ssr && node scripts/prerender.mjs",
    "legal:check": "node scripts/check-legal-lock.mjs",
    "legal:check-staged": "node scripts/check-legal-lock.mjs --staged",
    "legal:refresh-lock": "node scripts/refresh-legal-lock.mjs",
    "lint": "eslint .",
    "lint:strict": "PACK_LINT_STRICT=1 npm run lint",
    "preview": "vite preview",
    "validate:meta-browser": "node scripts/validate-meta-browser-events.mjs",
    "capture:live-activity-lab": "node scripts/capture-live-activity-lab.mjs",
    "sync:live-activity-lab": "node scripts/sync-live-activity-lab.mjs",
    "sync:app-cloudfront-waf": "node scripts/sync-app-cloudfront-waf.mjs",
    "deploy:app-origin": "node scripts/deploy-app-origin.mjs",
    "test:e2e": "npm run test:e2e:guard && playwright test -c playwright.config.ts",
    "test:e2e:headed": "npm run test:e2e:guard && playwright test -c playwright.config.ts --headed",
    "test:e2e:live": "npm run test:e2e:guard && E2E_BASE_URL=https://trypackai.com playwright test -c playwright.config.ts",
    "deploy": "node scripts/deploy-github-pages.mjs",
    "test": "jest",
    "test:e2e:guard": "node scripts/check-e2e-subscribe-safety.mjs"
  },
  "dependencies": {
    "@doneai/schemas": "*",
    "@fontsource-variable/inter": "5.2.8",
    "@tanstack/react-query": "5.90.2",
    "@tanstack/react-query-devtools": "5.90.2",
    "@types/topojson-client": "3.1.5",
    "airports-json": "1.0.0",
    "d3-geo": "3.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "11.0.5",
    "history": "5.3.0",
    "jwt-decode": "4.0.0",
    "lucide-react": "0.563.0",
    "react": "18.3.1",
    "react-compiler-runtime": "19.0.0-beta-ebf51a3-20250411",
    "react-dom": "18.3.1",
    "react-google-recaptcha": "3.1.0",
    "react-helmet-async": "2.0.5",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.5.2",
    "styled-components": "6.1.8",
    "topojson-client": "3.1.0",
    "us-atlas": "3.0.1",
    "world-atlas": "2.0.2",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "9.9.1",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.14",
    "@types/node": "22.14.1",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.2.3",
    "@types/react-google-recaptcha": "2.1.9",
    "@types/styled-components": "5.1.34",
    "@vitejs/plugin-react": "4.3.1",
    "babel-plugin-react-compiler": "19.0.0-beta-ebf51a3-20250411",
    "babel-plugin-styled-components": "2.1.4",
    "eslint": "9.9.1",
    "eslint-plugin-react-hooks": "5.1.0-rc.0",
    "eslint-plugin-react-refresh": "0.4.11",
    "gh-pages": "6.3.0",
    "globals": "15.9.0",
    "jest": "29.7.0",
    "jest-axe": "10.0.0",
    "jest-environment-jsdom": "29.7.0",
    "terser": "5.43.1",
    "ts-jest": "29.3.2",
    "typescript": "5.5.3",
    "typescript-eslint": "8.3.0",
    "vite": "5.4.2",
    "vite-imagetools": "7.0.5"
  },
  "overrides": {
    "axios": "1.14.0",
    "mdast-util-to-hast": "13.2.1"
  },
  "browserslist": [
    "defaults and supports es6-module",
    "maintained node versions",
    "> 1%",
    "last 2 chrome versions",
    "last 2 firefox versions",
    "last 2 safari versions",
    "last 2 edge versions",
    "not ie 11"
  ]
}
